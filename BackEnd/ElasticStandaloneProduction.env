

# แก้จาก http:// เป็น https:// และใช้ URL ของ Elastic Cloud ที่คุณ curl ผ่าน
ELASTIC_APM_SERVER_URL=https://b329e4682f5a4731bb28e4719291303e.apm.ap-southeast-1.aws.cloud.es.io:443

# ชื่อ Service สำหรับแสดงในหน้า Kibana
ELASTIC_APM_SERVICE_NAME=my-securevideo-backend

# ระบุ Environment ให้ชัดเจน
ELASTIC_APM_ENVIRONMENT=development

# สั่งให้ Agent ทำงาน
ELASTIC_APM_ACTIVE=true

# สำคัญ: ลบช่องว่าง (Space) หน้า-หลังเครื่องหมาย = ออก และใช้ Token ที่ curl ผ่าน
ELASTIC_APM_SECRET_TOKEN=daKOcKJAjufYfSQLz2


