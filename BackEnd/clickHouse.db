CREATE TABLE "app_db".video_watch_events
(
    -- ✅ เพิ่ม event_id สำหรับ dedup
    event_id               String,
    video_id               String,
    user_id                String,
    session_id             String,
    event_type             LowCardinality(String),
    watch_duration_seconds UInt32,
    total_watch_seconds    UInt32,
    current_time_seconds   UInt32,
    device_type            LowCardinality(String),
    country_code           LowCardinality(String),
    event_time             DateTime,
    _inserted_at           DateTime DEFAULT now()
)
ENGINE = ReplacingMergeTree(_inserted_at)
PARTITION BY toYYYYMM(event_time)
-- ✅ เพิ่ม event_id ใน ORDER BY เพื่อ dedup ระดับ ClickHouse
ORDER BY (video_id, event_time, event_id)
SETTINGS index_granularity = 8192;

