-- ถ้าต้องการเก็บ currentTime จริงๆ
CREATE TABLE video_watch_events (
    video_id String,
    user_id String,
    watch_duration_seconds Float32,
    device_type String,
    event_time DateTime,
    country_code String,
    current_time Float32  -- ✅ เพิ่มฟิลด์นี้
) ENGINE = MergeTree()
ORDER BY (event_time, video_id);