# ===== Vault AppRole Configuration =====
# ได้จาก setup-vault-agent.ps1 script

# AppRole Authentication (ปลอดภัยสำหรับ production)
VAULT_ADDR=http://localhost:8200
VAULT_ROLE_ID=your_role_id_here
VAULT_SECRET_ID=your_secret_id_here

# ⚠️ Token Authentication (development only - ใช้ AppRole แทนสำหรับ production)
# VAULT_TOKEN=root

# ===== Elasticsearch =====
ELASTICSEARCH_HOST=https://your-es-domain:9200

# ===== MongoDB =====
MONGO_URI=mongodb://localhost:27017/video-platform

# ===== Redis =====
REDIS_URL=redis://localhost:6379

# ===== Stripe =====
STRIPE_PUBLIC_KEY=pk_test_xxxxx
STRIPE_SECRET_KEY=sk_test_xxxxx

# ===== Server Config =====
NODE_ENV=development
PORT=3000

# ===== CORS =====
CORS_ORIGIN=http://localhost:5173,https://toteja.co

# ===== JWT =====
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# ===== AWS S3 (optional) =====
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key

# ===== CloudFront (optional) =====
CLOUDFRONT_DOMAIN=d123456.cloudfront.net
CLOUDFRONT_KEY_PAIR_ID=APKAJ...
CLOUDFRONT_PRIVATE_KEY_PATH=/path/to/private-key.pem

# ===== K Plus Payment (optional) =====
KPAY_CONSUMER_ID=your_consumer_id
KPAY_CONSUMER_SECRET=your_consumer_secret
KPAY_BASE_URL=https://www.saletalk.co/kpl-payment/api/
KPAY_CALLBACK_URL=https://yourdomain.com/api/purchase/callback
